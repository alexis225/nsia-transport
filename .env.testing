APP_NAME="NSIA Transport"
APP_ENV=testing
APP_KEY=base64:vZgxZaTyckp3ubKQuw2Fa6Z85k97yHJDAL0Jzt9ITeM=          # laisser vide — Laravel génère automatiquement via php artisan key:generate --env=testing
APP_DEBUG=true
APP_URL=http://localhost

# ── Base de données dédiée aux tests ────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=testing_bd_transport
DB_USERNAME=postgres
DB_PASSWORD=root

# ── Cache & Queue en mémoire (pas de Redis réel) ─────────────
CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array

# ── Mail intercepté (aucun email réel envoyé) ────────────────
MAIL_MAILER=array

# ── Broadcasting désactivé ───────────────────────────────────
BROADCAST_CONNECTION=log

# ── Socialite OAuth (fausses clés pour les tests) ────────────
GOOGLE_CLIENT_ID=fake-google-client-id
GOOGLE_CLIENT_SECRET=fake-google-secret
GOOGLE_REDIRECT_URI=http://localhost/auth/google/callback

MICROSOFT_CLIENT_ID=fake-microsoft-client-id
MICROSOFT_CLIENT_SECRET=fake-microsoft-secret
MICROSOFT_REDIRECT_URI=http://localhost/auth/microsoft/callback
MICROSOFT_TENANT_ID=common

# ── S3 désactivé en test ─────────────────────────────────────
FILESYSTEM_DISK=local